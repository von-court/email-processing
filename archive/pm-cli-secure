#!/bin/bash
set -e

PAT_FILE="/run/secrets/proton-pat.env"
ENV_FILE="/tmp/pm-cli-env-$$"
PASS_ITEM="pass://EPA/ProtonMail Bridge/password"
PASS_CLI="/usr/local/bin/pass-cli"
PM_CLI="/usr/local/bin/pm-cli"

if [ ! -f "$PAT_FILE" ]; then
    echo "Error: Secret file not found at $PAT_FILE" >&2
    exit 1
fi

while IFS= read -r line; do
    eval "export $line"
done < "$PAT_FILE"
export PROTON_PASS_SESSION_DIR="/tmp/pass-sandbox"

echo "PM_CLI_BRIDGE_PASSWORD=$PASS_ITEM" > "$ENV_FILE"
trap "rm -f \"$ENV_FILE\"" EXIT

exec $PASS_CLI run --env-file "$ENV_FILE" --no-masking -- $PM_CLI "$@"
